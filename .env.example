# S1000D-RAG local configuration example.
# Copy to .env for local use only. Do not commit real .env files or secrets.

# Data location (safe default points at the bundled S1000D sample path).
# S1000D_DATA_DIR=docs/S1000D Issue 6/Bike Data Set for Release number 6 R2

# Runtime backend. llama_cpp_python is the current in-process backend; llama_server is reserved for server mode wiring.
S1000D_MODEL_BACKEND=llama_cpp_python

# 16GB VRAM text model candidates:
# - qwen36_27b_iq4: unsloth/Qwen3.6-27B-GGUF, prefer IQ4_NL or IQ4_XS
# - gemma4_26b_iq4: unsloth/gemma-4-26B-A4B-it-GGUF, prefer UD-IQ4_NL
# - light_qwen35_9b: lightweight fallback
S1000D_TEXT_MODEL_PROFILE=qwen36_27b_iq4
S1000D_TEXT_MODEL_PATH=/absolute/path/to/local/text-model.gguf

# Vision-language profile. Requires both local GGUF and mmproj files before use.
S1000D_VLM_MODEL_PROFILE=qwen3_vl_8b_q4
S1000D_VLM_MODEL_PATH=/absolute/path/to/local/qwen3-vl-8b-q4_k_m.gguf
S1000D_VLM_MMPROJ_PATH=/absolute/path/to/local/mmproj.gguf

# Embedding/reranker can be Hugging Face model IDs or local paths.
S1000D_EMBEDDING_MODEL=BAAI/bge-m3
S1000D_RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# Legacy compatibility aliases still supported when S1000D_* values are unset:
# GGUF_MODEL_PATH=/absolute/path/to/local/text-model.gguf
# EMBEDDING_MODEL_PATH=/absolute/path/to/local/embedding-model
# RERANKER_MODEL_PATH=/absolute/path/to/local/reranker-model
