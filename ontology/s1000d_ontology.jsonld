      "rdfs:label": "Do not ride a bicycle with no grips on the handlebar.",
      "s1000d:dmc": "S1000DBIKE-AAA-DA2-2-0-00AA-720A-A",
      "s1000d:text": "Do not ride a bicycle with no grips on the handlebar."
    },
    {
