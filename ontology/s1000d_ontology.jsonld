    },
    {
      "@id": "caution:S1000DBIKE-AAA-D00-0-0-00AA-320A-A:1:wheels-must-be-true-for-rim-brakes-to-work-effec",
      "@type": "s1000d:Caution",
      "rdfs:label": "Wheels must be true for rim brakes to work effectively.",
      "s1000d:dmc": "S1000DBIKE-AAA-D00-0-0-00AA-320A-A",
      "s1000d:text": "Wheels must be true for rim brakes to work effectively."
    },
    {
      "@id": "caution:S1000DBIKE-AAA-D00-0-0-00AA-663A-A:1:when-you-remove-the-rear-wheel-to-repair-a-punct",
      "@type": "s1000d:Caution",
      "rdfs:label": "When you remove the rear wheel to repair a puncture, disconnect the brake arm from the chain stay.",
      "s1000d:dmc": "S1000DBIKE-AAA-D00-0-0-00AA-663A-A",
      "s1000d:text": "When you remove the rear wheel to repair a puncture, disconnect the brake arm from the chain stay."
    },
    {
      "@id": "caution:S1000DBIKE-AAA-DA0-1-0-00AA-921A-A:1:be-careful-with-sharp-or-hard-tools-they-can-cau",
      "@type": "s1000d:Caution",
      "rdfs:label": "Be careful with sharp or hard tools. They can cause damage to the inner tube.",
      "s1000d:dmc": "S1000DBIKE-AAA-DA0-1-0-00AA-921A-A",
      "s1000d:text": "Be careful with sharp or hard tools. They can cause damage to the inner tube."
    },
    {
      "@id": "caution:S1000DBIKE-AAA-DA0-3-0-00AA-520A-A:1:be-sure-to-operate-on-a-white-surface-in-order-t",
      "@type": "s1000d:Caution",
      "rdfs:label": "Be sure to operate on a white surface in order to prevent lost of part that could fall on the floor.",
      "s1000d:dmc": "S1000DBIKE-AAA-DA0-3-0-00AA-520A-A",
      "s1000d:text": "Be sure to operate on a white surface in order to prevent lost of part that could fall on the floor."
    },
    {
      "@id": "caution:S1000DBIKE-AAA-DA2-1-0-00AA-720A-A:1:do-not-tighten-the-stem-bolt-too-much-you-can-ca",
      "@type": "s1000d:Caution",
      "rdfs:label": "Do not tighten the stem bolt too much. You can cause damage to the headset bearings if you tighten the stem too much.",
      "s1000d:dmc": "S1000DBIKE-AAA-DA2-1-0-00AA-720A-A",
      "s1000d:text": "Do not tighten the stem bolt too much. You can cause damage to the headset bearings if you tighten the stem too much."
    },
    {
      "@id": "caution:S1000DBIKE-AAA-DA2-1-0-00AA-720A-A:2:the-stem-bolt-does-not-safety-the-stem",
      "@type": "s1000d:Caution",
      "rdfs:label": "The stem bolt does not safety the stem.",
      "s1000d:dmc": "S1000DBIKE-AAA-DA2-1-0-00AA-720A-A",
      "s1000d:text": "The stem bolt does not safety the stem."
    },
    {
      "@id": "caution:S1000DBIKE-AAA-DA2-2-0-00AA-720A-A:1:make-sure-the-handlebar-is-correctly-aligned-in-",
      "@type": "s1000d:Caution",
      "rdfs:label": "Make sure the handlebar is correctly aligned in the center of the stem.",
      "s1000d:dmc": "S1000DBIKE-AAA-DA2-2-0-00AA-720A-A",
      "s1000d:text": "Make sure the handlebar is correctly aligned in the center of the stem."
    },
    {
      "@id": "caution:S1000DBIKE-AAA-DA4-1-0-00AA-241A-A:1:do-not-get-lubrication-oil-into-the-brake-system",
      "@type": "s1000d:Caution",
      "rdfs:label": "Do not get lubrication oil into the brake system. Oil in the break system can affect the efficiency of the bake system. Do not get oil onto the floor where it can easily get transferred onto the brake system.",
      "s1000d:dmc": "S1000DBIKE-AAA-DA4-1-0-00AA-241A-A",
      "s1000d:text": "Do not get lubrication oil into the brake system. Oil in the break system can affect the efficiency of the bake system. Do not get oil onto the floor where it can easily get transferred onto the brake system."
    },
    {
      "@id": "caution:S1000DBIKE-AAA-DA5-2-0-00AA-251C-A:1:make-sure-you-do-not-lose-the-bearings-from-the-",
      "@type": "s1000d:Caution",
      "rdfs:label": "Make sure you do not lose the bearings from the hub. Be prepared to catch the bearings if they fall out. Missing bearings can cause damage to the hub.",
      "s1000d:dmc": "S1000DBIKE-AAA-DA5-2-0-00AA-251C-A",
      "s1000d:text": "Make sure you do not lose the bearings from the hub. Be prepared to catch the bearings if they fall out. Missing bearings can cause damage to the hub."
    },
