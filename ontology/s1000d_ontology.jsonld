    {
      "@id": "warning:S1000DBIKE-AAA-D00-0-0-00AA-320A-A:1:incorrect-tightening-force-can-result-in-compone",
      "@type": "s1000d:Warning",
      "rdfs:label": "Incorrect tightening force can result in component failure, leading to loss of control.",
      "s1000d:dmc": "S1000DBIKE-AAA-D00-0-0-00AA-320A-A",
      "s1000d:text": "Incorrect tightening force can result in component failure, leading to loss of control."
    },
    {
      "@id": "warning:S1000DBIKE-AAA-D00-0-0-00AA-320A-A:2:riding-the-bike-on-a-tire-that-has-visible-damag",
      "@type": "s1000d:Warning",
      "rdfs:label": "Riding the bike on a tire that has visible damage could cause the tire to fail, leading to loss of control.",
      "s1000d:dmc": "S1000DBIKE-AAA-D00-0-0-00AA-320A-A",
      "s1000d:text": "Riding the bike on a tire that has visible damage could cause the tire to fail, leading to loss of control."
    },
    {
      "@id": "warning:S1000DBIKE-AAA-D00-0-0-00AA-320A-A:3:riding-a-wheel-that-is-at-the-end-of-its-usable-",
      "@type": "s1000d:Warning",
      "rdfs:label": "Riding a wheel that is at the end of its usable life can result in wheel failure and loss of control.",
      "s1000d:dmc": "S1000DBIKE-AAA-D00-0-0-00AA-320A-A",
      "s1000d:text": "Riding a wheel that is at the end of its usable life can result in wheel failure and loss of control."
    },
    {
      "@id": "warning:S1000DBIKE-AAA-DA2-2-0-00AA-520A-A:1:do-not-ride-a-bicycle-with-no-grips-on-the-handl",
      "@type": "s1000d:Warning",
      "rdfs:label": "Do not ride a bicycle with no grips on the handlebar. This can cause the hands of the rider to slip.",
      "s1000d:dmc": "S1000DBIKE-AAA-DA2-2-0-00AA-520A-A",
      "s1000d:text": "Do not ride a bicycle with no grips on the handlebar. This can cause the hands of the rider to slip."
    },
    {
      "@id": "warning:S1000DBIKE-AAA-DA2-2-0-00AA-720A-A:1:do-not-ride-the-bicycle-until-the-grips-have-bec",
      "@type": "s1000d:Warning",
      "rdfs:label": "Do not ride the bicycle until the grips have become dry and are firmly held in position. If the grips are wet, your hands can move off the grips when you ride the bicycle.",
      "s1000d:dmc": "S1000DBIKE-AAA-DA2-2-0-00AA-720A-A",
      "s1000d:text": "Do not ride the bicycle until the grips have become dry and are firmly held in position. If the grips are wet, your hands can move off the grips when you ride the bicycle."
    },
    {
      "@id": "warning:S1000DBIKE-AAA-DA2-2-0-00AA-720A-A:2:do-not-ride-a-bicycle-with-no-grips-on-the-handl",
