    {
      "@id": "caution:S1000DBIKE-AAA-D00-0-0-00AA-121A-A:1:if-the-position-of-the-pads-is-too-low-on-the-ri",
      "@type": "s1000d:Caution",
      "rdfs:label": "If the position of the pads is too low on the rim, as shown in , the pads can move. This could cause the separation of the spokes from their mountings., they could slip off causing the spokes to be torn out of their mountings.",
      "s1000d:dmc": "S1000DBIKE-AAA-D00-0-0-00AA-121A-A",
      "s1000d:text": "If the position of the pads is too low on the rim, as shown in , the pads can move. This could cause the separation of the spokes from their mountings., they could slip off causing the spokes to be torn out of their mountings."
    },
    {
      "@id": "caution:S1000DBIKE-AAA-D00-0-0-00AA-258A-A:1:do-not-use-a-that-has-high-pressure-a-water-hose",
      "@type": "s1000d:Caution",
      "rdfs:label": "Do not use a that has high pressure. A water hose that has high pressure can cause some parts to become loose or full of water.",
      "s1000d:dmc": "S1000DBIKE-AAA-D00-0-0-00AA-258A-A",
      "s1000d:text": "Do not use a that has high pressure. A water hose that has high pressure can cause some parts to become loose or full of water."
    },
    {
      "@id": "caution:S1000DBIKE-AAA-D00-0-0-00AA-258A-A:2:do-not-point-the-hose-directly-at-the-hub-or-at-",
      "@type": "s1000d:Caution",
      "rdfs:label": "Do not point the hose directly at the hub or at the bottom bracket bearings. This can cause damage to the parts.",
      "s1000d:dmc": "S1000DBIKE-AAA-D00-0-0-00AA-258A-A",
      "s1000d:text": "Do not point the hose directly at the hub or at the bottom bracket bearings. This can cause damage to the parts."
    },
    {
      "@id": "caution:S1000DBIKE-AAA-D00-0-0-00AA-258A-A:3:apply-in-accordance-with-the-instruction-on-the-",
      "@type": "s1000d:Caution",
      "rdfs:label": "Apply in accordance with the instruction on the container. The substance may cause damage to the Bike paint if it is not applied correctly.",
      "s1000d:dmc": "S1000DBIKE-AAA-D00-0-0-00AA-258A-A",
      "s1000d:text": "Apply in accordance with the instruction on the container. The substance may cause damage to the Bike paint if it is not applied correctly."
    },
    {
      "@id": "caution:S1000DBIKE-AAA-D00-0-0-00AA-258B-A:1:do-not-use-a-that-has-high-pressure-a-water-hose",
