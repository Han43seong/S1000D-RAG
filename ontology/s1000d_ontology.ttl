warning:S1000DBIKE-AAA-D00-0-0-00AA-043A-A:1:if-you-operate-the-front-brake-without-the-rear- a s1000d:Warning ;
  rdfs:label "If you operate the front brake without the rear brake you can cause a crash." .

warning:S1000DBIKE-AAA-D00-0-0-00AA-131A-A:1:do-not-ride-with-a-cracked-stem a s1000d:Warning ;
  rdfs:label "Do not ride with a cracked stem" .

warning:S1000DBIKE-AAA-D00-0-0-00AA-258A-A:1:do-not-get-into-your-eyes-if-it-gets-into-your-e a s1000d:Warning ;
  rdfs:label "Do not get into your eyes. If it gets into your eyes, wash them immediately in clean warm water (H 2 O)." .

warning:S1000DBIKE-AAA-D00-0-0-00AA-258A-A:2:do-not-get-into-your-eyes-if-it-gets-into-your-e a s1000d:Warning ;
  rdfs:label "Do not get into your eyes. If it gets into your eyes, wash them immediately in clean warm water (H 2 O)." .

warning:S1000DBIKE-AAA-D00-0-0-00AA-258B-A:1:do-not-get-into-your-eyes-if-it-gets-into-your-e a s1000d:Warning ;
  rdfs:label "Do not get into your eyes. If it gets into your eyes, wash them immediately in clean warm water (H 2 O)." .

warning:S1000DBIKE-AAA-D00-0-0-00AA-258B-A:2:do-not-get-into-your-eyes-if-it-gets-into-your-e a s1000d:Warning ;
  rdfs:label "Do not get into your eyes. If it gets into your eyes, wash them immediately in clean warm water (H 2 O)." .

warning:S1000DBIKE-AAA-D00-0-0-00AA-320A-A:1:incorrect-tightening-force-can-result-in-compone a s1000d:Warning ;
  rdfs:label "Incorrect tightening force can result in component failure, leading to loss of control." .

warning:S1000DBIKE-AAA-D00-0-0-00AA-320A-A:2:riding-the-bike-on-a-tire-that-has-visible-damag a s1000d:Warning ;
  rdfs:label "Riding the bike on a tire that has visible damage could cause the tire to fail, leading to loss of control." .

warning:S1000DBIKE-AAA-D00-0-0-00AA-320A-A:3:riding-a-wheel-that-is-at-the-end-of-its-usable- a s1000d:Warning ;
  rdfs:label "Riding a wheel that is at the end of its usable life can result in wheel failure and loss of control." .

warning:S1000DBIKE-AAA-DA2-2-0-00AA-520A-A:1:do-not-ride-a-bicycle-with-no-grips-on-the-handl a s1000d:Warning ;
  rdfs:label "Do not ride a bicycle with no grips on the handlebar. This can cause the hands of the rider to slip." .

warning:S1000DBIKE-AAA-DA2-2-0-00AA-720A-A:1:do-not-ride-the-bicycle-until-the-grips-have-bec a s1000d:Warning ;
  rdfs:label "Do not ride the bicycle until the grips have become dry and are firmly held in position. If the grips are wet, your hands can move off the grips when you ride the bicycle." .

warning:S1000DBIKE-AAA-DA2-2-0-00AA-720A-A:2:do-not-ride-a-bicycle-with-no-grips-on-the-handl a s1000d:Warning ;
  rdfs:label "Do not ride a bicycle with no grips on the handlebar." .

warning:S1000DBIKE-AAA-DA4-1-0-00AA-241A-A:1:is-a-very-dangerous-substance-do-not-get-it-onto a s1000d:Warning ;
  rdfs:label "is a very dangerous substance. Do not get it onto your skin. Use it in a well ventilated area. If you swallow it seek immediate medical advice. If it gets into your eyes wash your eyes in clean water and seek medical advice." .

warning:S1000DBIKE-AAA-DA4-1-0-00AA-241A-A:2:is-a-very-dangerous-substance-do-not-get-it-onto a s1000d:Warning ;
  rdfs:label "is a very dangerous substance. Do not get it onto your skin. Use it in a well ventilated area. If you swallow it seek immediate medical advice. If it gets into your eyes wash your eyes in clean water and seek medical advice." .

